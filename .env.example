# Copiez ce fichier en .env et ajustez les valeurs. Toutes les variables
# sont préfixées RUSTMON_ pour éviter toute collision avec d'autres
# variables d'environnement du VPS. Un redémarrage du processus est
# nécessaire pour appliquer un changement.

# Seuils d'alerte (en pourcentage) — défaut : 90.0
RUSTMON_CPU_THRESHOLD_PCT=90.0
RUSTMON_RAM_THRESHOLD_PCT=90.0
RUSTMON_DISK_THRESHOLD_PCT=90.0

# Fréquence de collecte des métriques (secondes) — défaut : 5
RUSTMON_SAMPLE_INTERVAL_SECS=5

# Rétention de l'historique en base (jours) — défaut : 7
RUSTMON_RETENTION_DAYS=7

# Chemin du fichier SQLite — défaut : data.db
RUSTMON_DB_PATH=data.db

# Adresse d'écoute HTTP — défaut : 0.0.0.0:3000
RUSTMON_BIND_ADDR=0.0.0.0:3000

# Point de montage à scanner pour les métriques disque — défaut : /
# En Docker, si le disque hôte est monté en lecture seule sur /host
# (volume /:/host:ro), mettre RUSTMON_DISK_PATH=/host pour lire le vrai
# disque du VPS plutôt que le filesystem du conteneur.
RUSTMON_DISK_PATH=/

# Notifications par e-mail via un serveur SMTP — optionnel.
# Si RUSTMON_SMTP_HOST ou RUSTMON_EMAIL_FROM est absent, l'envoi
# d'e-mail est désactivé.
RUSTMON_SMTP_HOST=
# Port SMTP — défaut : 587
RUSTMON_SMTP_PORT=587
RUSTMON_SMTP_USER=
RUSTMON_SMTP_PASSWORD=
RUSTMON_EMAIL_FROM=
# Liste de destinataires séparés par des virgules
RUSTMON_EMAIL_TO=

# Webhook générique (ex: Discord/Slack) pour les alertes — optionnel.
RUSTMON_WEBHOOK_URL=
